    local SliderFill=Create("Frame",{Size=UDim2.new((default-min)/(max-min),0,1,0),BackgroundColor3=WHITE,BorderSizePixel=0,ZIndex=13,Parent=SliderBg})
    Create("UICorner",{CornerRadius=UDim.new(1,0),Parent=SliderFill})
    local dragging2=false
    local function UpdateSlider(input)
        local rx=math.clamp((input.Position.X-SliderBg.AbsolutePosition.X)/SliderBg.AbsoluteSize.X,0,1)
        TweenService:Create(SliderFill,TweenInfo.new(0.08,Enum.EasingStyle.Quad),{Size=UDim2.new(rx,0,1,0)}):Play()
        local val=math.floor(min+(max-min)*rx)
        ValueBox.Text=tostring(val) if configKey then Config[configKey]=val end if callback then callback(val) end SaveConfig()
    end
    SliderBg.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging2=true UpdateSlider(i) end end)
    UserInputService.InputChanged:Connect(function(i) if dragging2 and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then UpdateSlider(i) end end)
    UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then dragging2=false end end)
    ValueBox.FocusLost:Connect(function()
        local num=tonumber(ValueBox.Text)
        if num and num>=min and num<=max then
            local val=math.floor(num) ValueBox.Text=tostring(val)
            TweenService:Create(SliderFill,TweenInfo.new(0.08,Enum.EasingStyle.Quad),{Size=UDim2.new((val-min)/(max-min),0,1,0)}):Play()
            if configKey then Config[configKey]=val end if callback then callback(val) end SaveConfig()
        else ValueBox.Text=tostring(Config[configKey] or default) end
    end)
    return SliderFill,ValueBox
end

