        or input.UserInputType==Enum.UserInputType.Gamepad3 or input.UserInputType==Enum.UserInputType.Gamepad4
    if gpe and isKB then return end if changingKeybind then return end
    local kc=input.KeyCode
    if (isKB and kc==KEYBINDS.ToggleGUI.PC) or (isGP and kc==KEYBINDS.ToggleGUI.Controller) then
        if MainContainer.Visible then
            TweenService:Create(MainContainer,TweenInfo.new(0.3,Enum.EasingStyle.Back,Enum.EasingDirection.In),{Size=UDim2.new(0,0,0,0)}):Play()
            task.wait(0.3) MainContainer.Visible=false MainContainer.Size=UDim2.new(0,600,0,400) OpenBtn.Visible=true
        else
            MainContainer.Visible=true OpenBtn.Visible=false
            MainContainer.Size=UDim2.new(0,0,0,0) MainContainer.Position=UDim2.new(0.5,0,0.5,0)
            TweenService:Create(MainContainer,TweenInfo.new(0.4,Enum.EasingStyle.Back,Enum.EasingDirection.Out),{Size=UDim2.new(0,600,0,400),Position=UDim2.new(0.5,-300,0.5,-200)}):Play()
        end return
    end
    if isGP and kc==KEYBINDS.AutoDuel.Controller then
        Config.AutoDuelActive=not Config.AutoDuelActive
        if Config.AutoDuelActive then autoDuelActivate() else stopInstantAutoDuel() end return
    end
    if isGP and kc==KEYBINDS.LockPlayer.Controller then
        Config.LockPlayerActive=not Config.LockPlayerActive
        if Config.LockPlayerActive then ActiveLockPlayerBtn.BackgroundColor3=WHITE ActiveLockPlayerBtn.TextColor3=BLACK startLockPlayer()
        else ActiveLockPlayerBtn.BackgroundColor3=DARK_GRAY ActiveLockPlayerBtn.TextColor3=WHITE stopLockPlayer() end return
    end
    if isGP and kc==KEYBINDS.Float.Controller then
        Config.FloatActive=not Config.FloatActive floatActive=Config.FloatActive
        if Config.FloatActive then ActiveFloatBtn.BackgroundColor3=WHITE ActiveFloatBtn.TextColor3=BLACK startFloat()
        else ActiveFloatBtn.BackgroundColor3=DARK_GRAY ActiveFloatBtn.TextColor3=WHITE stopFloat() end return
    end
end)

