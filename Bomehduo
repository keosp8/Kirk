-- PLAYER ESP (Highlight + Drawing lines + name labels)
local HIGHLIGHT_FILL    = Color3.fromRGB(255,255,255)
local HIGHLIGHT_COLOR   = Color3.fromRGB(255,255,255)
local LINE_COLOR        = Color3.fromRGB(255,255,255)
local FILL_TRANSPARENCY = 0.85
local NAME_MAX_SIZE     = 16
local NAME_MIN_SIZE     = 6
local DIST_MIN          = 10
local DIST_MAX          = 300

local espEnabled   = false
local espHighlights= {}
local espLines     = {}
local espLabels    = {}
local espConnections={}

local function clearESP(plr)
    if espHighlights[plr] then espHighlights[plr]:Destroy() espHighlights[plr]=nil end
    if espLines[plr]      then espLines[plr]:Destroy()      espLines[plr]=nil      end
    if espLabels[plr]     then espLabels[plr]:Destroy()     espLabels[plr]=nil     end
end

local function applyHighlight(plr,char)
    if espHighlights[plr] then espHighlights[plr]:Destroy() end
    local hl=Instance.new("Highlight")
    hl.FillColor=HIGHLIGHT_FILL hl.OutlineColor=HIGHLIGHT_COLOR
    hl.FillTransparency=FILL_TRANSPARENCY hl.OutlineTransparency=0
    hl.Adornee=char hl.Parent=char
    espHighlights[plr]=hl
end

local function setupESP(plr)
    if plr==Player then return end
    if plr.Character then applyHighlight(plr,plr.Character) end
    table.insert(espConnections,plr.CharacterAdded:Connect(function(char)
        task.wait(0.5)
        if espEnabled then applyHighlight(plr,char) end
    end))
    local line=Drawing.new("Line")
    line.Visible=false line.Color=LINE_COLOR line.Thickness=1.2 line.Transparency=1
    espLines[plr]=line
    local label=Drawing.new("Text")
    label.Visible=false label.Color=WHITE label.Outline=true label.OutlineColor=BLACK
    label.Center=true label.Font=Drawing.Fonts.UI label.Size=NAME_MAX_SIZE
    label.Text=plr.DisplayName.." [@"..plr.Name.."]"
    espLabels[plr]=label
end

local function enablePlayerESP()
    espEnabled=true
    for _,plr in ipairs(Players:GetPlayers()) do setupESP(plr) end
    table.insert(espConnections,Players.PlayerAdded:Connect(function(plr)
        task.wait(1) if espEnabled then setupESP(plr) end
    end))
    table.insert(espConnections,Players.PlayerRemoving:Connect(clearESP))
end

local function disablePlayerESP()
    espEnabled=false
    for _,plr in ipairs(Players:GetPlayers()) do
        if espHighlights[plr] then espHighlights[plr]:Destroy() espHighlights[plr]=nil end
        if espLines[plr]      then espLines[plr].Visible=false end
        if espLabels[plr]     then espLabels[plr].Visible=false end
    end
    for _,c in ipairs(espConnections) do if c and c.Connected then c:Disconnect() end end
    espConnections={}
end

-- ESP update loop (runs always, only draws when espEnabled)
RunService.Heartbeat:Connect(function()
    if not espEnabled then
        for _,l in pairs(espLines)  do l.Visible=false end
        for _,n in pairs(espLabels) do n.Visible=false end
        return
    end
    local cam=workspace.CurrentCamera
    local myChar=Player.Character
    local myRoot=myChar and myChar:FindFirstChild("HumanoidRootPart")
    local screenCenter=Vector2.new(cam.ViewportSize.X/2,cam.ViewportSize.Y)
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr==Player then continue end
        local line=espLines[plr] local label=espLabels[plr]
        if not line or not label then continue end
        local char=plr.Character
        if not char then line.Visible=false label.Visible=false continue end
        local root=char:FindFirstChild("HumanoidRootPart")
        if not root then line.Visible=false label.Visible=false continue end
        local pos,onScreen=cam:WorldToViewportPoint(root.Position)
        local headPos=cam:WorldToViewportPoint(root.Position+Vector3.new(0,3,0))
        local dist=myRoot and (myRoot.Position-root.Position).Magnitude or 999
        local t=math.clamp((dist-DIST_MIN)/(DIST_MAX-DIST_MIN),0,1)
        local fontSize=math.floor(NAME_MAX_SIZE+(NAME_MIN_SIZE-NAME_MAX_SIZE)*t)
        if onScreen and pos.Z>0 then
            line.From=screenCenter line.To=Vector2.new(pos.X,pos.Y) line.Visible=true
            label.Position=Vector2.new(headPos.X,headPos.Y-6) label.Size=fontSize
            label.Text=plr.DisplayName.." ["..math.floor(dist).."m]" label.Visible=true
        else
            line.Visible=false label.Visible=false
        end
    end
end)

-- PET ESP
local petESPEnabled=false local petESPThread=nil local currentPetESP=nil
local function parseValue(text)
    text=tostring(text or ""):gsub("%s","")
    local num,suffix=text:match("([%d%.]+)([KkMmBbTt]?)")
    if not num then return 0 end num=tonumber(num) or 0
    local m={K=1e3,M=1e6,B=1e9,T=1e12} return num*(m[(suffix or ""):upper()] or 1)
end
local function createPetESP(part,displayText,valueText)
    if currentPetESP then pcall(function() currentPetESP:Destroy() end) end
    if not part then return end
    local bb=Instance.new("BillboardGui") bb.Name="LXKCR_PetESP" bb.Size=UDim2.new(0,150,0,40)
    bb.AlwaysOnTop=true bb.StudsOffset=Vector3.new(0,3,0) bb.Adornee=part bb.Parent=CoreGui
    local n=Instance.new("TextLabel",bb) n.Size=UDim2.new(1,0,0,20) n.BackgroundTransparency=1
    n.Font=Enum.Font.GothamBold n.Text=displayText n.TextColor3=WHITE n.TextSize=14 n.TextStrokeTransparency=0.5
    local v=Instance.new("TextLabel",bb) v.Size=UDim2.new(1,0,0,20) v.Position=UDim2.new(0,0,0,20)
    v.BackgroundTransparency=1 v.Font=Enum.Font.GothamBold v.Text=valueText v.TextColor3=Color3.fromRGB(0,255,100)
    v.TextSize=14 v.TextStrokeTransparency=0.5 currentPetESP=bb
end
local function enablePetESP()
    petESPThread=task.spawn(function()
        while petESPEnabled do
            local debris=workspace:FindFirstChild("Debris")
            if debris then
                local best={value=-1,part=nil,text="",display=""}
                for _,template in ipairs(debris:GetChildren()) do
                    if template.Name=="FastOverheadTemplate" then
                        local sg=template:FindFirstChildOfClass("SurfaceGui")
                        if sg then
                            local genLabel=sg:FindFirstChild("Generation",true)
                            if genLabel and genLabel:IsA("TextLabel") then
                                local text=genLabel.Text or ""
                                if text~="" and (text:find("/s") or text:find("K") or text:find("M") or text:find("B")) then
                                    local val=parseValue(text)
                                    if val>best.value then
                                        local tp=sg.Adornee
                                        if tp and tp:IsA("BasePart") then
                                            local dn=sg:FindFirstChild("DisplayName",true)
                                            best={part=tp,value=val,text=text,display=dn and dn.Text or "Pet"}
                                        end
                                    end
                                end
                            end
                        end
                    end
                end
                if best.part and best.part.Parent then createPetESP(best.part,best.display,best.text) end
            end
            task.wait(0.5)
        end
        if currentPetESP then pcall(function() currentPetESP:Destroy() end) end
    end)
end
local function disablePetESP()
    if petESPThread then task.cancel(petESPThread) petESPThread=nil end
    if currentPetESP then pcall(function() currentPetESP:Destroy() end) currentPetESP=nil end
end

