    Create("TextLabel",{Size=UDim2.new(0.55,0,1,0),Position=UDim2.new(0,7,0,0),BackgroundTransparency=1,Text=name,TextColor3=WHITE,Font=Enum.Font.GothamSemibold,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12,Parent=TF})
    local KeyLabel=Create("TextButton",{Size=UDim2.new(0,16,0,16),Position=UDim2.new(0,120,0,9),BackgroundColor3=BTN_OFF,Text=keybind,TextColor3=WHITE,Font=Enum.Font.GothamBold,TextSize=9,ZIndex=12,Parent=TF})
    Create("UICorner",{CornerRadius=UDim.new(0,4),Parent=KeyLabel})
    local kbData={name=name,keybind=keybind,keyLabel=KeyLabel,configKey=configKey,callback=nil}
    table.insert(keybindButtons,kbData)
    KeyLabel.MouseButton1Click:Connect(function() changingKeybind=kbData KeybindChangeGui.Enabled=true KeybindTitle.Text="Press any key for "..name end)
    local ToggleBtn=Create("TextButton",{Size=UDim2.new(0,38,0,20),Position=UDim2.new(1,-45,0.5,-10),BackgroundColor3=BTN_OFF,Text="",ZIndex=12,Parent=TF})
    Create("UICorner",{CornerRadius=UDim.new(1,0),Parent=ToggleBtn})
    local Circle=Create("Frame",{Size=UDim2.new(0,16,0,16),Position=UDim2.new(0,2,0.5,-8),BackgroundColor3=Color3.fromRGB(200,200,200),ZIndex=13,Parent=ToggleBtn})
    Create("UICorner",{CornerRadius=UDim.new(1,0),Parent=Circle})
    local enabled=false
    local function setState(state)
        enabled=state
        if enabled then
            ToggleBtn.BackgroundColor3=WHITE Circle.BackgroundColor3=BLACK
            TweenService:Create(Circle,TweenInfo.new(0.18),{Position=UDim2.new(1,-18,0.5,-8)}):Play()
        else
            ToggleBtn.BackgroundColor3=BTN_OFF Circle.BackgroundColor3=Color3.fromRGB(200,200,200)
            TweenService:Create(Circle,TweenInfo.new(0.18),{Position=UDim2.new(0,2,0.5,-8)}):Play()
        end
    end
    ToggleBtn.MouseButton1Click:Connect(function() setState(not enabled) if callback then callback(enabled) end SaveConfig() end)
    kbData.callback=function() setState(not enabled) if callback then callback(enabled) end end
    return ToggleBtn,function() return enabled end,setState
end

UserInputService.InputBegan:Connect(function(input,gpe)
    if gpe or changingKeybind then return end
    if input.UserInputType==Enum.UserInputType.Keyboard then
        local kn=input.KeyCode.Name
        for _,kd in pairs(keybindButtons) do if kd.keybind==kn and kd.callback then kd.callback() end end
    end
end)

