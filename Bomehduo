-- Lightweight stars
local function CreateStarsAnimation(parent)
    for i=1,15 do
        local sz=math.random(2,4)
        local star=Create("Frame",{BackgroundColor3=WHITE,BackgroundTransparency=0.7,BorderSizePixel=0,ZIndex=1,Parent=parent,
            Position=UDim2.new(math.random(0,100)/100,0,math.random(0,100)/100,0),Size=UDim2.new(0,sz,0,sz)})
        Create("UICorner",{CornerRadius=UDim.new(1,0),Parent=star})
        task.spawn(function()
            local angle,radius=math.random(0,360),math.random(10,40)
            local cx,cy=star.Position.X.Scale,star.Position.Y.Scale
            local spd=math.random(3,8)/100
            while star and star.Parent do
                angle=angle+spd
                TweenService:Create(star,TweenInfo.new(0.8,Enum.EasingStyle.Linear),{
                    Position=UDim2.new(cx+math.cos(math.rad(angle))*radius/1000,0,cy+math.sin(math.rad(angle))*radius/1000,0)
                }):Play()
                task.wait(0.8)
            end
        end)
    end
end

