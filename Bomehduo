    local arrow=Create("TextLabel",{Size=UDim2.new(0,20,1,0),Position=UDim2.new(0,5,0,0),BackgroundTransparency=1,Text="v",TextColor3=WHITE,Font=Enum.Font.GothamBold,TextSize=11,ZIndex=12,Parent=header})
    Create("TextLabel",{Size=UDim2.new(1,-30,1,0),Position=UDim2.new(0,22,0,0),BackgroundTransparency=1,Text=groupName,TextColor3=GRAY,Font=Enum.Font.GothamSemibold,TextSize=10,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=12,Parent=header})
    local container=Create("Frame",{Size=UDim2.new(1,0,0,0),BackgroundTransparency=1,BorderSizePixel=0,ClipsDescendants=true,LayoutOrder=layoutOrder,ZIndex=11,Parent=parent})
    Create("UIListLayout",{Padding=UDim.new(0,4),SortOrder=Enum.SortOrder.LayoutOrder,Parent=container})
    buildSliders(container)
    task.defer(function()
        local layout=container:FindFirstChildOfClass("UIListLayout")
        local function refreshHeight()
            local h=layout.AbsoluteContentSize.Y
            if not collapsed then container.Size=UDim2.new(1,0,0,h) end
        end
        layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(refreshHeight)
        refreshHeight()
        headerBtn.MouseButton1Click:Connect(function()
            collapsed=not collapsed
            arrow.Text=collapsed and ">" or "v"
            local targetH=collapsed and 0 or layout.AbsoluteContentSize.Y
            TweenService:Create(container,TweenInfo.new(0.2,Enum.EasingStyle.Quad),{Size=UDim2.new(1,0,0,targetH)}):Play()
        end)
    end)
end

