-- AUTO DUEL
local autoDuelRunning=false
local autoDuelPatrolMode="none"
local autoDuelCurrentWaypoint=1
local autoDuelQueuedSide=nil
local autoDuelWasOne=false
local autoDuelSmoothVelX=0
local autoDuelSmoothVelZ=0

local RIGHT_WAYPOINTS={
    Vector3.new(-476.34,-6.58,25.68),
    Vector3.new(-482.30,-5.04,25.10),
    Vector3.new(-474.08,-6.99,26.43),
    Vector3.new(-476.54,-6.44,92.98),
    Vector3.new(-482.71,-5.04,94.07),
}
local LEFT_WAYPOINTS={
    Vector3.new(-476.35,-6.57,94.43),
    Vector3.new(-484.74,-4.94,95.11),
    Vector3.new(-474.08,-7.00,93.29),
    Vector3.new(-476.34,-6.58,25.68),
    Vector3.new(-482.30,-5.04,25.10),
}

local function isMidRound(text) return text and text:find(":")~=nil end
local function isCountdownNum(text) local n=tonumber(text) return n and n>=1 and n<=5 end
local function getTimerLabel()
    local ok,label=pcall(function()
        local pg=Player.PlayerGui
        local f1=pg:FindFirstChild("DuelsMachineTopFrame") if not f1 then return nil end
        local f2=f1:FindFirstChild("DuelsMachineTopFrame") if not f2 then return nil end
        local t=f2:FindFirstChild("Timer") if not t then return nil end
        return t:FindFirstChild("Label")
    end)
    return ok and label or nil
end
local function getMyBaseSide()
    local pf=workspace:FindFirstChild("Plots") if not pf then return nil end
    for _,plot in ipairs(pf:GetChildren()) do
        if isMyBase(plot.Name) then
            local podiums=plot:FindFirstChild("AnimalPodiums")
            if podiums then
                local first=podiums:GetChildren()[1]
                if first then local pos=first:GetPivot().Position return pos.Z>60 and "right" or "left" end
            end
            local pp=plot:GetPivot().Position return pp.Z>60 and "right" or "left"
        end
    end
    return nil
end
local function autoDuelGetSpeed()
    return autoDuelCurrentWaypoint>=3 and Config.AutoDuelSpeed2 or Config.AutoDuelSpeed1
end

RunService.Heartbeat:Connect(function(dt)
    if autoDuelPatrolMode=="none" then
        autoDuelSmoothVelX=autoDuelSmoothVelX*0.7
        autoDuelSmoothVelZ=autoDuelSmoothVelZ*0.7
        return
    end
    local char=Player.Character if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return end
    local wps=autoDuelPatrolMode=="right" and RIGHT_WAYPOINTS or LEFT_WAYPOINTS
    local target=wps[autoDuelCurrentWaypoint]
    local tXZ=Vector3.new(target.X,0,target.Z)
    local cXZ=Vector3.new(hrp.Position.X,0,hrp.Position.Z)
    local dist=(tXZ-cXZ).Magnitude
    if dist>3 then
        local dir=(tXZ-cXZ).Unit
        local spd=autoDuelGetSpeed()
        hrp.AssemblyLinearVelocity=Vector3.new(dir.X*spd,hrp.AssemblyLinearVelocity.Y,dir.Z*spd)
        autoDuelSmoothVelX=dir.X*spd
        autoDuelSmoothVelZ=dir.Z*spd
    else
        autoDuelSmoothVelX=autoDuelSmoothVelX*0.6
        autoDuelSmoothVelZ=autoDuelSmoothVelZ*0.6
        hrp.AssemblyLinearVelocity=Vector3.new(autoDuelSmoothVelX,hrp.AssemblyLinearVelocity.Y,autoDuelSmoothVelZ)
        if autoDuelCurrentWaypoint==#wps then
            local completedSide=autoDuelPatrolMode
            autoDuelPatrolMode="none" autoDuelCurrentWaypoint=1
            autoDuelSmoothVelX=0 autoDuelSmoothVelZ=0
            hrp.AssemblyLinearVelocity=Vector3.new(0,hrp.AssemblyLinearVelocity.Y,0)
            autoDuelRunning=false autoDuelQueuedSide=completedSide autoDuelWasOne=false
            ActiveAutoDuelBtn.Text="WAITING..."
            TweenService:Create(ActiveAutoDuelBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(255,200,50),TextColor3=BLACK}):Play()
        else
            autoDuelCurrentWaypoint=autoDuelCurrentWaypoint+1
        end
    end
end)

local function startInstantAutoDuel(forceSide)
    if autoDuelRunning then return end
    autoDuelRunning=true autoDuelQueuedSide=nil autoDuelWasOne=false
    autoDuelCurrentWaypoint=1 autoDuelSmoothVelX=0 autoDuelSmoothVelZ=0
    autoDuelPatrolMode=forceSide or getMyBaseSide() or "right"
    ActiveAutoDuelBtn.BackgroundColor3=WHITE ActiveAutoDuelBtn.TextColor3=BLACK
    ActiveAutoDuelBtn.Text="AUTO DUEL ●"
end
local function stopInstantAutoDuel()
    autoDuelRunning=false autoDuelPatrolMode="none" autoDuelCurrentWaypoint=1
    autoDuelQueuedSide=nil autoDuelWasOne=false autoDuelSmoothVelX=0 autoDuelSmoothVelZ=0
    Config.AutoDuelActive=false
    local char=Player.Character
    if char and char:FindFirstChild("HumanoidRootPart") then char.HumanoidRootPart.AssemblyLinearVelocity=Vector3.zero end
    ActiveAutoDuelBtn.BackgroundColor3=DARK_GRAY ActiveAutoDuelBtn.TextColor3=WHITE
    ActiveAutoDuelBtn.Text="AUTO DUEL"
end
local function autoDuelActivate()
    local label=getTimerLabel()
    local text=label and label.Text or ""
    if isMidRound(text) then
        startInstantAutoDuel(nil)
    else
        local side=getMyBaseSide()
        autoDuelQueuedSide=side autoDuelWasOne=false
        ActiveAutoDuelBtn.Text="WAITING..."
        TweenService:Create(ActiveAutoDuelBtn,TweenInfo.new(0.2),{BackgroundColor3=Color3.fromRGB(255,200,50),TextColor3=BLACK}):Play()
    end
end
ActiveAutoDuelBtn.MouseButton1Click:Connect(function()
    Config.AutoDuelActive=not Config.AutoDuelActive
    if Config.AutoDuelActive then autoDuelActivate() else stopInstantAutoDuel() end
    SaveConfig()
end)
task.spawn(function()
    while true do
        local label=getTimerLabel()
        if label then
            label:GetPropertyChangedSignal("Text"):Connect(function()
                local text=label.Text
                if not autoDuelQueuedSide or autoDuelRunning then return end
                local num=tonumber(text)
                if num==1 then autoDuelWasOne=true return end
                if autoDuelWasOne then
                    autoDuelWasOne=false
                    local side=autoDuelQueuedSide
                    startInstantAutoDuel(side)
                end
            end)
            break
        end
        task.wait(1)
    end
end)

-- LOCK PLAYER
local lockPlayerRunning=false local lockMoveConn=nil local lockLookConn=nil local lockAlignOri=nil local lockAttach=nil
local LOCK_MOVE_SPEED=56.5 local LOCK_LOOK_DIST=50
local function nearestPlayerTarget()
    local char=Player.Character if not char then return nil,math.huge end
    local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return nil,math.huge end
    local closest,minDist=nil,math.huge
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=Player and plr.Character then
            local tHRP=plr.Character:FindFirstChild("HumanoidRootPart")
            local tHum=plr.Character:FindFirstChildOfClass("Humanoid")
            if tHRP and tHum and tHum.Health>0 then
                local d=(tHRP.Position-hrp.Position).Magnitude
                if d<minDist then minDist=d closest=tHRP end
            end
        end
    end
    return closest,minDist
end
local function closestLookTarget()
    local char=Player.Character if not char then return nil end
    local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return nil end
    local nearest,shortest=nil,LOCK_LOOK_DIST
    for _,plr in ipairs(Players:GetPlayers()) do
        if plr~=Player and plr.Character and plr.Character:FindFirstChild("HumanoidRootPart") then
            local d=(hrp.Position-plr.Character.HumanoidRootPart.Position).Magnitude
            if d<shortest then shortest=d nearest=plr.Character.HumanoidRootPart end
        end
    end
    return nearest
end
local function startLockPlayer()
    if lockPlayerRunning then return end
    lockPlayerRunning=true
    local char=Player.Character if not char then return end
    local hrp=char:FindFirstChild("HumanoidRootPart") if not hrp then return end
    local hum=char:FindFirstChildOfClass("Humanoid")
    if hum then hum.AutoRotate=false end
    lockAttach=Instance.new("Attachment",hrp)
    lockAlignOri=Instance.new("AlignOrientation")
    lockAlignOri.Attachment0=lockAttach lockAlignOri.Mode=Enum.OrientationAlignmentMode.OneAttachment
    lockAlignOri.MaxTorque=Vector3.new(math.huge,math.huge,math.huge) lockAlignOri.Responsiveness=1000
    lockAlignOri.RigidityEnabled=true lockAlignOri.Parent=hrp
    lockLookConn=RunService.RenderStepped:Connect(function()
        if not lockPlayerRunning or not hrp or not lockAlignOri then return end
        local t=closestLookTarget() if not t then return end
        lockAlignOri.CFrame=CFrame.lookAt(hrp.Position,Vector3.new(t.Position.X,hrp.Position.Y,t.Position.Z))
    end)
    local bat=Player.Character and Player.Character:FindFirstChild("Bat")
    local bp=Player:FindFirstChildOfClass("Backpack")
    if not bat and bp then bat=bp:FindFirstChild("Bat") end
    if bat and bat.Parent~=Player.Character then
        local h=Player.Character:FindFirstChildOfClass("Humanoid") if h then h:EquipTool(bat) end
    end
    lockMoveConn=RunService.Heartbeat:Connect(function()
        if not lockPlayerRunning or not hrp then return end
        hrp.CanCollide=false
        local target=nearestPlayerTarget() if not target then return end
        hrp.AssemblyLinearVelocity=(target.Position-hrp.Position).Unit*LOCK_MOVE_SPEED
    end)
end
local function stopLockPlayer()
    lockPlayerRunning=false
    if lockMoveConn then lockMoveConn:Disconnect() lockMoveConn=nil end
    if lockLookConn then lockLookConn:Disconnect() lockLookConn=nil end
    if lockAlignOri then lockAlignOri:Destroy() lockAlignOri=nil end
    if lockAttach   then lockAttach:Destroy()    lockAttach=nil   end
    local char=Player.Character
    if char then
        local hrp=char:FindFirstChild("HumanoidRootPart")
        if hrp then hrp.CanCollide=true hrp.AssemblyLinearVelocity=Vector3.zero end
        local hum=char:FindFirstChildOfClass("Humanoid") if hum then hum.AutoRotate=true end
    end
end
