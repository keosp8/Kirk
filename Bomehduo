local function CreateToggle(parent,name,configKey,layoutOrder,callback)
    local keybind=Config.Keybinds[configKey] or "?"
    local TF=Create("Frame",{Size=UDim2.new(1,0,0,35),BackgroundColor3=BTN_BG,BorderSizePixel=0,LayoutOrder=layoutOrder,ZIndex=11,Parent=parent})
    Create("UICorner",{CornerRadius=UDim.new(0,6),Parent=TF})
